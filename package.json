{
	"name": "cast",
	"version": "0.4.0",
	"description": "Coding agent harness with swappable personas",
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"bin": {
		"cast": "./cast.sh"
	},
	"scripts": {
		"start": "node --import tsx ./src/index.ts",
		"build": "node ./scripts/build.mjs",
		"check": "tsc --noEmit && biome check src/ test/",
		"lint": "biome check src/ test/",
		"format": "biome format --write src/ test/",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@types/react": "^19.2.17",
		"ink": "^7.1.0",
		"node-pty": "^1.1.0",
		"openai": "^4.73.0",
		"react": "^19.2.7",
		"tsx": "^4.19.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"esbuild": "^0.28.1",
		"typescript": "^5.6.0",
		"vitest": "^3.2.0"
	}
}
