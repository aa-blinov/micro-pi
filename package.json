{
	"name": "cast",
	"version": "0.7.1",
	"description": "Role-based terminal agent harness with 13 built-in personas",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"bin": {
		"cast": "./cast.sh"
	},
	"scripts": {
		"start": "node --import tsx ./src/index.ts",
		"build": "node ./scripts/build.mjs",
		"check": "tsc --noEmit && biome check src/ test/",
		"lint": "biome check src/ test/",
		"format": "biome format --write src/ test/",
		"test": "vitest run",
		"test:watch": "vitest",
		"e2e:plan": "bash scripts/e2e-plan-mode.sh",
		"build-site": "node scripts/build-site.mjs"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@types/react": "^19.2.17",
		"ink": "^7.1.0",
		"openai": "^4.73.0",
		"react": "^19.2.7",
		"tsx": "^4.19.0",
		"undici": "^8.7.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"esbuild": "^0.28.1",
		"marked": "^18.0.6",
		"typescript": "^5.6.0",
		"vitest": "^3.2.0"
	}
}
